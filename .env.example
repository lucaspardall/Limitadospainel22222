# ────────────────────────────────────────────────────────────────
#  Limitados Painel — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your actual .env to version control.
# ────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://limitados:CHANGE_ME@localhost:5432/limitados_painel

# ─── Auth ────────────────────────────────────────────────────────
# JWT secret — use a long random string (min 32 chars)
# Generate with: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_STRING

# ─── API Server ──────────────────────────────────────────────────
# Port the Express API runs on (default: 8080)
PORT=8080

# Node environment
NODE_ENV=production

# ─── Frontend ────────────────────────────────────────────────────
# Port the Vite dev server runs on (dev only — production uses build)
VITE_PORT=19623

# ─── Agent (VPS side) ────────────────────────────────────────────
# These are set when running cs2_agent.py on the VPS, NOT in .env
# --token    : your chosen agent secret (must match what you set in the panel)
# --port     : agent HTTP port (default 7777, open on firewall)
# --rcon-host: CS2 server IP (usually 127.0.0.1)
# --rcon-port: CS2 RCON port (default 27015)
# --rcon-password: CS2 RCON password (set in server.cfg)
# --cs2-dir  : CS2 installation path (e.g. /home/steam/cs2)
